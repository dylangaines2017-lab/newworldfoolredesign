---
import Layout from "../layouts/Layout.astro";
import { films } from "../data/films";

const indexed = films.map((film, i) => ({ film, i }));
const completed = indexed.filter(({ film }) => film.status === 'completed');
const upcoming  = indexed.filter(({ film }) => film.status !== 'completed');
---

<Layout title="Our Work — New World Fool Productions" noSnap>
  <div class="work-page">
    <header class="page-hero">
      <h1><em>Short</em> films.</h1>
    </header>

    {upcoming.length > 0 && (
      <>
        <header class="section-hero">
          <h2 class="section-title">Upcoming</h2>
          {completed.length > 0 && (
            <a href="#now-showing" class="section-scroll-link">Now Showing ↓</a>
          )}
        </header>
        <section class="films-grid">
          {upcoming.map(({ film, i }) => (
            <a href={`/films/${film.slug}`} class="film-card" data-index={String(i)}>
              <div class="card-image" data-cursor>
                {film.videoEmbedUrl ? (
                  <iframe
                    src={film.videoEmbedUrl}
                    class="card-video"
                    allow="autoplay; fullscreen"
                    allowfullscreen
                    loading="lazy"
                    title={film.title}
                  />
                ) : (
                  <img src={film.poster ?? film.stillImage} alt={film.title} loading="eager" />
                )}
                <div class="card-overlay" />
                {film.statusLabel && <span class={`status-badge status-${film.status}`}>{film.statusLabel}</span>}
              </div>
              <div class="card-info">
                <div class="card-meta"><span class="card-year">{film.year}</span></div>
                <h2 class="card-title">{film.title}</h2>
                <div class="card-credits">
                  {(() => {
                    const dir = film.credits.find(c => c.role === 'Director' || c.role === 'Directors');
                    const wri = film.credits.find(c => c.role === 'Writer' || c.role === 'Writers');
                    return (
                      <>
                        {dir && <span class="credit-line"><span class="credit-role">Directed by</span> {dir.name}</span>}
                        {wri && <span class="credit-line"><span class="credit-role">Written by</span> {wri.name}</span>}
                      </>
                    );
                  })()}
                </div>
              </div>
            </a>
          ))}
        </section>
      </>
    )}

    {completed.length > 0 && (
      <>
        <header class="section-hero" id="now-showing">
          <h2 class="section-title">Now Showing</h2>
        </header>
        <section class="films-grid">
          {completed.map(({ film, i }) => (
            <a href={`/films/${film.slug}`} class="film-card" data-index={String(i)}>
              <div class="card-image" data-cursor>
                {film.videoEmbedUrl ? (
                  <iframe
                    src={film.videoEmbedUrl}
                    class="card-video"
                    allow="autoplay; fullscreen"
                    allowfullscreen
                    loading="lazy"
                    title={film.title}
                  />
                ) : (
                  <img src={film.poster ?? film.stillImage} alt={film.title} loading="eager" />
                )}
                <div class="card-overlay" />
                {film.statusLabel && <span class={`status-badge status-${film.status}`}>{film.statusLabel}</span>}
              </div>
              <div class="card-info">
                <div class="card-meta"><span class="card-year">{film.year}</span></div>
                <h2 class="card-title">{film.title}</h2>
                <div class="card-credits">
                  {(() => {
                    const dir = film.credits.find(c => c.role === 'Director' || c.role === 'Directors');
                    const wri = film.credits.find(c => c.role === 'Writer' || c.role === 'Writers');
                    return (
                      <>
                        {dir && <span class="credit-line"><span class="credit-role">Directed by</span> {dir.name}</span>}
                        {wri && <span class="credit-line"><span class="credit-role">Written by</span> {wri.name}</span>}
                      </>
                    );
                  })()}
                </div>
              </div>
            </a>
          ))}
        </section>
      </>
    )}

    <!-- Film modal -->
    <div class="film-modal" id="film-modal" aria-hidden="true">
      <div class="modal-backdrop"></div>
      <button class="modal-close" aria-label="Close">✕</button>
      <div class="modal-scroll">

        <section class="m-hero">
          <div class="m-poster-wrap">
            <img class="m-poster" src="" alt="" />
            <h2 class="m-film-title"></h2>
          </div>
          <div class="m-hero-inner">
            <div class="m-film-credits"></div>
            <div class="m-desc-row">
              <div class="m-synopsis-col">
                <span class="m-synopsis-label">Synopsis</span>
                <p class="m-film-tagline"></p>
              </div>
              <div class="m-desc-aside">
                <span class="m-status-badge"></span>
                <a class="m-btn-watch" href="" target="_blank" rel="noopener noreferrer" style="display:none">
                  Watch Now
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
                  </svg>
                </a>
                <a class="m-btn-imdb" href="" target="_blank" rel="noopener noreferrer">
                  View on IMDb
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              </div>
            </div>
            <div class="m-film-meta-row" id="m-film-meta-row">
              <div class="m-meta-col">
                <span class="m-meta-label">Genre</span>
                <span class="m-meta-value" id="m-meta-genre"></span>
              </div>
              <div class="m-meta-col">
                <span class="m-meta-label">Runtime</span>
                <span class="m-meta-value" id="m-meta-runtime"></span>
              </div>
              <div class="m-meta-col">
                <span class="m-meta-label">Year</span>
                <span class="m-meta-value" id="m-meta-year"></span>
              </div>
            </div>
          </div>
        </section>

        <section class="m-gallery-section" id="m-gallery-section"></section>
        <section class="m-laurels-section" id="m-laurels-section"></section>

      </div>
      <!-- Lightbox (above scroll, inside modal) -->
      <div class="m-lightbox" id="m-lightbox" aria-hidden="true">
        <button class="m-lightbox-close" id="m-lightbox-close">×</button>
        <img src="" alt="" id="m-lightbox-img" />
      </div>
    </div>

    <!-- Page loading overlay -->
    <div class="video-loader" id="page-loader">
      <img src="/logo.png" alt="" class="loader-logo" />
    </div>

    <div id="films-data" hidden data-films={JSON.stringify(films.map(f => ({
      slug: f.slug,
      title: f.title,
      year: f.year,
      category: f.category,
      description: f.description,
      statusLabel: f.statusLabel,
      status: f.status,
      genre: f.genre ?? null,
      runtime: f.runtime ?? null,
      poster: f.poster ?? f.stillImage,
      stills: f.stills,
      laurels: f.laurels,
      imdbUrl: f.imdbUrl ?? null,
      credits: f.credits,
      videoEmbedUrl: f.videoEmbedUrl ?? null,
    })))}></div>

  </div>
</Layout>

<style>
  .work-page {
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .page-hero {
    padding: 5rem 2.5rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-hero {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 2rem;
    padding: 0rem 2.5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 400;
    line-height: 1;
    color: #F0ECE0;
    letter-spacing: 0.02em;
  }

  .section-scroll-link {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    white-space: nowrap;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .section-scroll-link:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  h1 {
    font-family: "Instrument Serif", serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 400;
    line-height: 0.85;
    color: #F0ECE0;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }

  h1 em {
    font-style: italic;
    background: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .films-grid {
    display: flex;
    flex-direction: column;
    gap: 10rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2.5rem 8rem;
  }

  .film-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 5rem;
    text-decoration: none;
    color: inherit;
    opacity: 0;
    transform: translateY(var(--card-y, 32px));
    transition: opacity 0.7s ease, transform 0.7s ease;
  }

  .film-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Alternate: even rows flip poster to the right */
  .film-card:nth-child(even) {
    flex-direction: row-reverse;
  }

  .film-card:hover .card-image img {
    filter: grayscale(0%);
    transform: scale(1.04);
  }

  .card-image {
    position: relative;
    width: 60%;
    flex-shrink: 0;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #0A0A08;
    border-radius: 12px;
    cursor: none;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%);
    transition: filter 0.4s ease, transform 0.5s ease;
  }

  .card-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 50%);
    pointer-events: none;
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }

  .status-festival {
    background: rgba(200, 169, 110, 0.25);
    color: #C8A96E;
    border: 1px solid rgba(200, 169, 110, 0.45);
  }

  .status-post-production {
    background: rgba(15, 15, 15, 0.45);
    color: #F0ECE0;
    border: 1px solid rgba(240, 236, 224, 0.3);
  }

  .status-pre-production {
    background: rgba(15, 15, 15, 0.45);
    color: rgba(240, 236, 224, 0.75);
    border: 1px solid rgba(240, 236, 224, 0.2);
  }

  .card-info {
    flex: 1;
    text-align: left;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .card-year {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    color: rgba(240, 236, 224, 0.6);
    text-transform: uppercase;
  }

  .card-title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(3rem, 5vw, 5.5rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: #F0ECE0;
    line-height: 1;
    margin-bottom: 1.25rem;
    transition: color 0.2s;
  }

  .card-credits {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .credit-line {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: rgba(240, 236, 224, 0.55);
  }

  .credit-role {
    color: #C8A96E;
  }

  @media (max-width: 768px) {
    .films-grid {
      gap: 4rem;
      padding: 3rem 1.5rem 5rem;
    }

    .film-card,
    .film-card:nth-child(even) {
      flex-direction: column;
      gap: 1.5rem;
    }

    .card-image {
      width: 100%;
      aspect-ratio: 16/9;
    }

    .card-info {
      width: 100%;
      padding: 0;
    }
  }

  /* ── Film modal ── */
  .film-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    transition: opacity 0.35s ease;
  }

  .film-modal[aria-hidden="true"] {
    opacity: 0;
    pointer-events: none;
  }

  .film-modal[aria-hidden="false"] {
    opacity: 1;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: #000;
  }

  .modal-close {
    position: fixed;
    top: 1.5rem;
    right: 2rem;
    background: none;
    border: none;
    color: rgba(240, 236, 224, 0.5);
    font-size: 2rem;
    font-family: "JetBrains Mono", monospace;
    cursor: pointer;
    z-index: 1001;
    transition: color 0.2s;
    padding: 0.5rem;
    line-height: 1;
  }

  .modal-close:hover { color: #F0ECE0; }

  .modal-scroll {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    z-index: 1;
    background: #0A0A08;
  }

  /* ── Hero ── */

  .m-poster-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    transform-origin: center center;
  }

  .m-poster {
    width: 100%;
    height: 75vh;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .m-hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 2.5rem 5rem;
  }

  .m-film-title {
    position: absolute;
    bottom: 2rem;
    left: 0;
    right: 0;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2.5rem 0.25em;
    font-family: "Instrument Serif", serif;
    font-size: clamp(7rem, 12vw, 12rem);
    font-weight: 400;
    font-style: italic;
    line-height: 0.9;
    letter-spacing: 0.02em;
    background: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    opacity: 0;
  }

  @keyframes m-title-enter {
    from { opacity: 0; transform: translateY(0.75rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .film-modal[aria-hidden="false"] .m-film-title {
    animation: m-title-enter 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.65s both;
  }

  .m-desc-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .m-synopsis-col {
    grid-column: 1 / 3;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .m-synopsis-label {
    font-family: "Instrument Serif", serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 400;
    color: #F0ECE0;
  }

  .m-film-tagline {
    font-size: 1.2rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(240, 236, 224, 0.65);
  }

  .m-film-meta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-top: 2rem;
  }

  .m-meta-col {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .m-meta-label {
    font-family: "Inter", sans-serif;
    font-size: clamp(1.4rem, 2vw, 2rem);
    font-weight: 400;
    color: #F0ECE0;
  }

  .m-meta-value {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: rgba(240, 236, 224, 0.65);
    line-height: 1.6;
  }

  .m-desc-aside {
    grid-column: 3;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.85rem;
  }

  .m-status-badge {
    display: inline-block;
    font-family: "JetBrains Mono", monospace;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.6rem 1.25rem;
    border-radius: 12px;
  }

  .m-status-festival {
    background: rgba(200, 169, 110, 0.15);
    color: #C8A96E;
    border: 1px solid rgba(200, 169, 110, 0.35);
  }

  .m-status-post-production {
    background: rgba(240, 236, 224, 0.08);
    color: rgba(240, 236, 224, 0.6);
    border: 1px solid rgba(240, 236, 224, 0.18);
  }

  .m-status-pre-production {
    background: rgba(240, 236, 224, 0.05);
    color: rgba(240, 236, 224, 0.6);
    border: 1px solid rgba(240, 236, 224, 0.12);
  }

  .m-film-credits {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
    margin-bottom: 2.5rem;
    padding-top: 1rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid #1a1a18;
  }

  :global(.m-credit-col) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  :global(.m-credit-starring) {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :global(.m-starring-names) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.35rem 2.5rem;
  }

  :global(.m-credit-role) {
    font-family: "Instrument Serif", serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 400;
    color: #F0ECE0;
    margin-bottom: 0.4rem;
  }

  :global(.m-credit-name) {
    font-family: "Inter", sans-serif;
    font-size: clamp(1.1rem, 1.5vw, 1.7rem);
    font-weight: 400;
    color: #F0ECE0;
    line-height: 1.4;
  }

  .m-btn-imdb {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    width: fit-content;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .m-btn-imdb:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  .m-btn-imdb svg {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .m-btn-watch {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8A96E;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 1rem 2rem;
    border: 1px solid #C8A96E;
    border-radius: 8px;
    background-image: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    background-position: left center;
    transition: background-size 0.4s ease, color 0.3s ease;
  }

  .m-btn-watch:hover {
    background-size: 100% 100%;
    color: #0A0A08;
  }

  .m-btn-watch svg {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .m-btn-watch:hover svg {
    transform: translate(2px, -2px);
  }

  /* ── Gallery ── */
  .m-gallery-section {
    max-width: 1100px;
    margin: 0 auto;
  }

  :global(.m-stills-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }

  :global(.m-still-item) {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #0A0A08;
    border-radius: 12px;
  }

  :global(.m-still-item img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Laurels ── */
  .m-laurels-section {
    padding: 5rem 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
    border-top: 1px solid #1a1a18;
  }

  :global(.m-laurels-heading) {
    font-family: "Instrument Serif", serif;
    font-size: clamp(2.5rem, 4vw, 4rem);
    font-weight: 400;
    color: #F0ECE0;
    margin-bottom: 2.5rem;
  }

  :global(.m-laurels-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  :global(.m-laurel-item) {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  :global(.m-laurel-item img) {
    height: 120px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    opacity: 0.85;
    transition: opacity 0.2s;
    filter: brightness(0) invert(1);
  }

  :global(.m-laurel-item img:hover) { opacity: 1; }

  /* ── Lightbox ── */
  .m-lightbox {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    z-index: 10;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .m-lightbox[aria-hidden="false"] { display: flex; }

  .m-lightbox img {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
  }

  .m-lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: rgba(240, 236, 224, 0.6);
    font-size: 2rem;
    cursor: pointer;
    line-height: 1;
    transition: color 0.2s;
  }

  .m-lightbox-close:hover { color: #F0ECE0; }

  @media (max-width: 900px) {
    .m-poster { height: 50vh; }
    :global(.m-stills-grid) { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .m-poster { height: 40vh; }
    .m-film-title { font-size: clamp(2.5rem, 12vw, 5rem); }
    .m-hero-inner,
    .m-gallery-section,
    .m-laurels-section {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    .m-film-credits { grid-template-columns: repeat(2, 1fr); }
    :global(.m-starring-names) { grid-template-columns: repeat(2, 1fr); }
    .m-synopsis-col { grid-column: 1 / -1; }
    .m-desc-aside {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    :global(.m-stills-grid) { grid-template-columns: 1fr; }
    :global(.m-laurels-grid) { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    :global(.m-laurel-item img) { height: 80px; }
  }

  /* ── Page loader ── */
  .video-loader {
    position: fixed;
    inset: 0;
    z-index: 9998;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.8s ease;
  }

  .video-loader.fade-out {
    opacity: 0;
    pointer-events: none;
  }

  .loader-logo {
    width: clamp(24rem, 60vw, 56rem);
    height: auto;
    animation: logo-pulse 2.2s ease-in-out infinite;
  }

  @keyframes logo-pulse {
    0%, 100% { opacity: 0.2;  transform: scale(0.82); }
    50%       { opacity: 0.65; transform: scale(1.12); }
  }
</style>

<script>
  // ── Page loader ──
  (() => {
    const loader = document.getElementById('page-loader') as HTMLElement | null;
    const videoIframes = Array.from(document.querySelectorAll<HTMLIFrameElement>('.card-video'));
    if (!loader) return;

    function dismiss() {
      loader!.classList.add('fade-out');
      loader!.addEventListener('transitionend', () => loader!.remove(), { once: true });
    }

    if (videoIframes.length === 0) {
      dismiss();
      return;
    }

    let remaining = videoIframes.length;
    const fallback = setTimeout(dismiss, 4000);

    videoIframes.forEach(iframe => {
      iframe.addEventListener('load', () => {
        remaining--;
        if (remaining <= 0) {
          clearTimeout(fallback);
          dismiss();
        }
      }, { once: true });
    });
  })();

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        } else {
          // Translate upward when exiting top (scrolled past), downward when below
          const above = entry.boundingClientRect.top < 0;
          (entry.target as HTMLElement).style.setProperty('--card-y', above ? '-32px' : '32px');
          entry.target.classList.remove('visible');
        }
      });
    },
    { threshold: 0.15, rootMargin: '-30% 0px -30% 0px' }
  );

  document.querySelectorAll('.film-card').forEach((card) => observer.observe(card));

  // ── Film modal ──
  const filmData: {
    slug: string; title: string; year: string; category: string; description: string;
    statusLabel: string; status: string; genre: string | null; runtime: string | null; poster: string;
    stills: string[]; laurels: { src: string; alt: string }[];
    imdbUrl: string | null; credits: { role: string; name: string }[];
    videoEmbedUrl: string | null;
  }[] = JSON.parse(
    (document.getElementById('films-data') as HTMLElement)?.dataset.films ?? '[]'
  );

  const modal       = document.getElementById('film-modal') as HTMLElement;
  const modalScroll = modal.querySelector<HTMLElement>('.modal-scroll');
  let   activeCard: HTMLElement | null = null;

  function getPosterTransform(cardEl: HTMLElement) {
    const imgRect = cardEl.querySelector<HTMLElement>('.card-image')!.getBoundingClientRect();
    const finalW  = window.innerWidth;
    const finalH  = window.innerHeight * 0.75;
    const sx = imgRect.width  / finalW;
    const sy = imgRect.height / finalH;
    const tx = (imgRect.left + imgRect.width  / 2) - finalW / 2;
    const ty = (imgRect.top  + imgRect.height / 2) - finalH / 2;
    return `translate(${tx}px, ${ty}px) scale(${sx}, ${sy})`;
  }

  function openModal(index: number, card: HTMLElement | null) {
    const f = filmData[index];
    if (!f) return;

    const poster   = modal.querySelector<HTMLImageElement>('.m-poster');
    const title    = modal.querySelector<HTMLElement>('.m-film-title');
    const tagline  = modal.querySelector<HTMLElement>('.m-film-tagline');
    const badge    = modal.querySelector<HTMLElement>('.m-status-badge');
    const credits  = modal.querySelector<HTMLElement>('.m-film-credits');
    const btnImdb  = modal.querySelector<HTMLAnchorElement>('.m-btn-imdb');
    const gallery  = document.getElementById('m-gallery-section');
    const laurels  = document.getElementById('m-laurels-section');

    if (poster)  { poster.src = f.poster; poster.alt = f.title; }
    if (title)   title.textContent = f.title;
    if (tagline) tagline.textContent = f.description;

    const metaGenre   = document.getElementById('m-meta-genre');
    const metaRuntime = document.getElementById('m-meta-runtime');
    const metaYear    = document.getElementById('m-meta-year');
    const metaRow     = document.getElementById('m-film-meta-row');
    if (metaGenre)   metaGenre.textContent   = f.genre   ?? '—';
    if (metaRuntime) metaRuntime.textContent = f.runtime ?? '—';
    if (metaYear)    metaYear.textContent    = f.year;
    if (metaRow)     metaRow.style.display   = (f.genre || f.runtime) ? '' : 'none';

    const btnWatch = modal.querySelector<HTMLAnchorElement>('.m-btn-watch');
    if (f.status === 'completed') {
      if (badge) { badge.textContent = ''; badge.style.display = 'none'; }
      if (btnWatch) {
        const videoId = f.videoEmbedUrl?.match(/\/video\/(\d+)/)?.[1];
        btnWatch.href = videoId ? `https://vimeo.com/${videoId}` : (f.imdbUrl ?? '#');
        btnWatch.style.display = 'inline-flex';
      }
    } else {
      if (badge) {
        badge.textContent = f.statusLabel;
        badge.className   = `m-status-badge m-status-${f.status}`;
        badge.style.display = '';
      }
      if (btnWatch) btnWatch.style.display = 'none';
    }

    if (credits) {
      credits.innerHTML = f.credits
        .map(c => {
          const nameList = c.name.split(', ').map(n => n.trim());
          if (c.role === 'Starring') {
            const nameItems = nameList
              .map(n => `<span class="m-credit-name">${n}</span>`)
              .join('');
            return `<div class="m-credit-starring"><span class="m-credit-role">${c.role}</span><div class="m-starring-names">${nameItems}</div></div>`;
          }
          const names = nameList
            .map(n => `<span class="m-credit-name">${n}</span>`)
            .join('');
          return `<div class="m-credit-col"><span class="m-credit-role">${c.role}</span>${names}</div>`;
        })
        .join('');
    }

    if (btnImdb) {
      if (f.imdbUrl) {
        btnImdb.href = f.imdbUrl;
        btnImdb.style.display = 'inline-flex';
      } else {
        btnImdb.style.display = 'none';
      }
    }

    if (gallery) {
      if (f.stills.length > 0) {
        gallery.innerHTML = `<div class="m-stills-grid">${f.stills.map((src, i) =>
          `<div class="m-still-item" data-src="${src}"><img src="${src}" alt="${f.title} still ${i + 1}" loading="lazy" /></div>`
        ).join('')}</div>`;
        gallery.style.display = '';
      } else {
        gallery.innerHTML = '';
        gallery.style.display = 'none';
      }
    }

    if (laurels) {
      if (f.laurels.length > 0) {
        laurels.innerHTML = `<h3 class="m-laurels-heading">Festivals &amp; Awards</h3><div class="m-laurels-grid">${f.laurels.map(l =>
          `<div class="m-laurel-item"><img src="${l.src}" alt="${l.alt}" loading="lazy" /></div>`
        ).join('')}</div>`;
        laurels.style.display = '';
      } else {
        laurels.innerHTML = '';
        laurels.style.display = 'none';
      }
    }

    if (modalScroll) modalScroll.scrollTop = 0;
    activeCard = card;

    // FLIP open: snap poster-wrap to card, then spring to natural position
    const posterWrap = modal.querySelector<HTMLElement>('.m-poster-wrap');
    if (posterWrap && card?.querySelector('.card-image')) {
      posterWrap.style.transition = 'none';
      posterWrap.style.transform  = getPosterTransform(card);

      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      posterWrap.getBoundingClientRect(); // force reflow
      posterWrap.style.transition = 'transform 0.65s cubic-bezier(0.16, 1, 0.3, 1)';
      posterWrap.style.transform  = '';
    } else {
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
  }

  function closeModal() {
    const posterWrap = modal.querySelector<HTMLElement>('.m-poster-wrap');

    if (posterWrap && activeCard?.querySelector('.card-image')) {
      if (modalScroll) modalScroll.scrollTop = 0;

      // Match poster animation duration to the modal's CSS opacity fade (0.35s)
      // so both finish together — same mechanic as the nav overlay + logo
      posterWrap.style.transition = 'transform 0.35s cubic-bezier(0.4, 0, 1, 1)';
      posterWrap.style.transform  = getPosterTransform(activeCard);

      modal.setAttribute('aria-hidden', 'true'); // triggers 0.35s opacity fade
      document.body.style.overflow = '';

      setTimeout(() => {
        posterWrap.style.transition = 'none';
        posterWrap.style.transform  = '';
        activeCard = null;
      }, 380);
    } else {
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      if (posterWrap) { posterWrap.style.transition = 'none'; posterWrap.style.transform = ''; }
      activeCard = null;
    }
  }

  // ── Lightbox (inside modal) ──
  const lightbox    = document.getElementById('m-lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('m-lightbox-img') as HTMLImageElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.setAttribute('aria-hidden', 'false');
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
  }

  document.getElementById('m-lightbox-close')?.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

  document.querySelectorAll<HTMLAnchorElement>('.film-card').forEach(card => {
    card.addEventListener('click', (e) => {
      e.preventDefault();
      openModal(parseInt(card.dataset.index ?? '0'), card);
    });
  });

  modal.querySelector('.modal-backdrop')?.addEventListener('click', closeModal);
  modal.querySelector('.modal-close')?.addEventListener('click', closeModal);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      if (lightbox.getAttribute('aria-hidden') === 'false') closeLightbox();
      else closeModal();
    }
  });

  // Open modal from ?film= query param (linked from nav / accordion)
  const filmSlug = new URLSearchParams(window.location.search).get('film');
  if (filmSlug) {
    const idx = filmData.findIndex(f => f.slug === filmSlug);
    if (idx !== -1) openModal(idx, null);
  }
</script>
