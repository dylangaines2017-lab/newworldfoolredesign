---
import Layout from "../layouts/Layout.astro";

const sent = Astro.url.searchParams.get("sent") === "true";

const socials = [
  {
    label: "YouTube",
    href: "https://youtube.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "TikTok",
    href: "https://tiktok.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
];
---

<Layout title="Contact — New World Fool Productions" noSnap>
  <div class="contact-page">

    <header class="page-hero">
      <h1><em>Contact</em> us.</h1>
      <p class="subtitle">We'd love to collaborate with you on your next film, music video, or commercial. Reach out below and let's create something extraordinary together.</p>
    </header>

    {sent && (
      <div class="success-banner">
        Your message has been sent. We'll be in touch soon.
      </div>
    )}

    <div class="contact-body">

      <!-- Form -->
      <section class="form-section">
        <form
          class="contact-form"
          method="POST"
          action="https://formsubmit.co/newworldfoolproductions@gmail.com"
          id="contact-form"
        >
          <input type="hidden" name="_subject" value="New message from New World Fool Productions website" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_next" value="/contact?sent=true" />
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name <span class="required" aria-label="required">*</span></label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="email">Email <span class="required" aria-label="required">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" />
          </div>

          <div class="form-group">
            <label for="message">Message <span class="required" aria-label="required">*</span></label>
            <textarea id="message" name="message" rows="7" required></textarea>
          </div>

          <button type="submit" class="btn-submit">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 2 11 13"/>
              <path d="M22 2 15 22 11 13 2 9l20-7z"/>
            </svg>
          </button>
        </form>
      </section>

      <!-- Direct contact -->
      <aside class="contact-aside">
        <div class="aside-block">
          <span class="aside-label">Email us directly</span>
          <a href="mailto:hello@newworldfoolproductions.com" class="contact-email">
            <span class="email-text">hello@newworldfoolproductions.com</span>
            <svg class="email-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        </div>

        <div class="aside-block">
          <span class="aside-label">Financing &amp; Slate</span>
          <a href="mailto:invest@newworldfoolproductions.com" class="contact-email">
            <span class="email-text">invest@newworldfoolproductions.com</span>
            <svg class="email-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        </div>

        <div class="aside-block">
          <span class="aside-label">Festivals &amp; Press</span>
          <a href="mailto:press@newworldfoolproductions.com" class="contact-email">
            <span class="email-text">press@newworldfoolproductions.com</span>
            <svg class="email-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
        </div>

        <div class="aside-block">
          <span class="aside-label">Follow along</span>
          <div class="social-icons">
            {socials.map(({ label, href, icon }) => (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                class="social-icon"
                set:html={icon}
              />
            ))}
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>
  .contact-page {
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  /* ── Success banner ── */
  .success-banner {
    max-width: 1200px;
    margin: 2rem auto 0;
    padding: 1rem 2.5rem;
    background: rgba(200, 169, 110, 0.08);
    border: 1px solid rgba(200, 169, 110, 0.35);
    border-radius: 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8A96E;
  }

  /* ── Hero ── */
  .page-hero {
    padding: 5rem 2.5rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  h1 {
    font-family: "Instrument Serif", serif;
    font-size: clamp(5rem, 12vw, 10rem);
    font-weight: 400;
    line-height: 0.85;
    color: #F0ECE0;
    letter-spacing: 0.02em;
    margin-bottom: 3rem;
  }

  h1 em {
    font-style: italic;
    background: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .subtitle {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 300;
    line-height: 1.75;
    color: rgba(240, 236, 224, 0.6);
    max-width: 560px;
    margin-top: -1.5rem;
    margin-bottom: 3rem;
  }

  /* ── Body layout ── */
  .contact-body {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 2.5rem 6rem;
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 6rem;
    align-items: start;
  }

  /* ── Form ── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.75rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.5);
  }

  .required {
    color: #C8A96E;
  }

  input,
  textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(240, 236, 224, 0.12);
    border-radius: 8px;
    color: #F0ECE0;
    font-family: "Inter", sans-serif;
    font-size: 1rem;
    font-weight: 300;
    padding: 0.9rem 1.1rem;
    outline: none;
    transition: border-color 0.25s;
    width: 100%;
    resize: none;
    -webkit-appearance: none;
  }

  input::placeholder,
  textarea::placeholder {
    color: rgba(240, 236, 224, 0.25);
  }

  input:focus,
  textarea:focus {
    border-color: rgba(200, 169, 110, 0.55);
  }

  .btn-submit {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #C8A96E;
    background-color: transparent;
    background-image: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    background-size: 0% 100%;
    background-repeat: no-repeat;
    background-position: left center;
    border: 1px solid #C8A96E;
    border-radius: 8px;
    padding: 1rem 2rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    width: fit-content;
    transition: background-size 0.4s ease, color 0.3s ease;
  }

  .btn-submit:hover {
    background-size: 100% 100%;
    color: #0A0A08;
  }

  /* ── Aside ── */
  .contact-aside {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    padding-top: 0.25rem;
    border-left: 1px solid #1a1a18;
    padding-left: 3rem;
  }

  .aside-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .aside-label {
    font-family: "Instrument Serif", serif;
    font-size: clamp(1.8rem, 2.5vw, 2.5rem);
    font-weight: 400;
    color: #F0ECE0;
  }

  .contact-email {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    white-space: nowrap;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    gap: 0.4rem;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .contact-email:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  .email-arrow {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .contact-email:hover .email-arrow {
    transform: translate(2px, -2px);
  }

  .social-icons {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .social-icon {
    color: rgba(240, 236, 224, 0.6);
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .social-icon:hover {
    color: #C8A96E;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .contact-body {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .contact-aside {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid #1a1a18;
      padding-top: 3rem;
    }
  }

  @media (max-width: 640px) {
    .page-hero,
    .contact-body {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
