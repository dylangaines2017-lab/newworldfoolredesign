---
const links = [
  { label: "Work", href: "/work" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const socials = [
  { label: "Instagram", href: "https://instagram.com" },
  { label: "TikTok",   href: "https://tiktok.com" },
  { label: "YouTube",   href: "https://youtube.com" },
];
---

<footer>
  <div class="footer-top">
    <nav class="footer-nav">
      {links.map(({ label, href }) => (
        <a href={href}>{label}</a>
      ))}
    </nav>

    <a href="/" class="footer-logo">
      <img src="/logo-cropped.png" alt="New World Fool Productions" class="footer-logo-img" />
    </a>

    <div class="footer-socials">
      {socials.map(({ label, href }) => (
        <a href={href} target="_blank" rel="noopener noreferrer">
          {label}
          <svg class="ext-icon" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      ))}
    </div>
  </div>

  <div class="footer-bottom">
    <span class="footer-copy">&copy; {new Date().getFullYear()} New World Fool Productions. All rights reserved.</span>
    <a href="#" class="footer-back-top">↑ Back to top</a>
  </div>


<style>
  footer {
    background: #0A0A08;
    border-top: 1px solid #1a1a18;
    padding: 4rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
    scroll-snap-align: start;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 3.5rem;
  }

  /* ── Logo ── */
  .footer-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s;
    line-height: 1;
  }

  .footer-logo:hover {
    opacity: 0.6;
  }

  .footer-logo-img {
    height: 10rem;
    width: auto;
    display: block;
  }

  /* ── Nav — right-aligned, flush against logo ── */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-end;
    justify-self: end;
  }

  .footer-nav a {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    width: fit-content;
    /* underline via background */
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .footer-nav a:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  /* ── Socials — left-aligned, flush against logo ── */
  .footer-socials {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    align-items: flex-start;
    justify-self: start;
  }

  .footer-socials a {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    width: fit-content;
    /* underline via background — applied only to the text portion via padding */
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .footer-socials a:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  .ext-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* ── Bottom bar ── */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 2rem;
    border-top: 1px solid #1a1a18;
  }

  .footer-copy {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.975rem;
    letter-spacing: 0.06em;
    color: rgba(240, 236, 224, 0.65);
    text-transform: uppercase;
  }

  .footer-back-top {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.975rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.65);
    text-decoration: none;
    width: fit-content;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .footer-back-top:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }


</style>

<script>
  document.querySelector('.footer-back-top')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
