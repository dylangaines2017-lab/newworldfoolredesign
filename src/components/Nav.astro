---
import { films } from "../data/films";

const filmsByCategory = films.reduce((acc, film) => {
  (acc[film.category] ??= []).push(film);
  return acc;
}, {} as Record<string, typeof films>);

const links = [
  { label: "Work", href: "/work" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];

const socials = [
  {
    label: "YouTube",
    href: "https://youtube.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  },
  {
    label: "TikTok",
    href: "https://tiktok.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>`,
  },
];

const currentPath = Astro.url.pathname;
---

<header id="site-header">
  <nav>
    <a href="/" class="logo">
      <img src="/logo-cropped.png" alt="New World Fool Productions" class="logo-img" />
    </a>

    <!-- Desktop links -->
    <ul class="desktop-links">
      {links.map(({ label, href }) => (
        <li>
          <a href={href} class={currentPath === href ? "active" : ""}>
            {label}
          </a>
        </li>
      ))}
      <li class="divider" aria-hidden="true"></li>
      {socials.map(({ label, href, icon }) => (
        <li>
          <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="social" set:html={icon} />
        </li>
      ))}
    </ul>

    <!-- Hamburger button (mobile only) -->
    <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false">
      <span class="bar bar-top"></span>
      <span class="bar bar-mid"></span>
      <span class="bar bar-bot"></span>
    </button>
  </nav>
</header>

<!-- Mobile menu overlay -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-nav">
    <ul class="mobile-links">
      <!-- Work with film dropdown -->
      <li class="work-item">
        <button class="work-toggle" id="work-toggle" aria-expanded="false">
          <span>Work</span>
          <svg class="work-chevron" width="14" height="8" viewBox="0 0 14 8" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="1,1 7,7 13,1"/>
          </svg>
        </button>
        <ul class="work-dropdown" id="work-dropdown">
          {Object.entries(filmsByCategory).map(([category, categoryFilms]) => (
            <>
              <li class="dropdown-category">{category}</li>
              {categoryFilms.slice(0, 3).map(film => (
                <li>
                  <a href={`/work?film=${film.slug}`} class="dropdown-film">
                    <span class="dropdown-title">{film.title}</span>
                    <span class="dropdown-year">{film.year}</span>
                  </a>
                </li>
              ))}
              {categoryFilms.length > 3 && (
                <li>
                  <a href="/work" class="dropdown-see-more">
                    <span class="see-more-full">Browse all {category}</span>
                    <span class="see-more-short">All {category}</span>
                    <svg class="see-more-arrow" xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 7h10v10"/>
                      <path d="M7 17 17 7"/>
                    </svg>
                  </a>
                </li>
              )}
            </>
          ))}
        </ul>
      </li>
      <!-- About & Contact -->
      {links.filter(l => l.label !== "Work").map(({ label, href }) => (
        <li>
          <a href={href} class={currentPath === href ? "active" : ""}>
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="mobile-socials">
      {socials.map(({ label, href, icon }) => (
        <a href={href} target="_blank" rel="noopener noreferrer" aria-label={label} class="mobile-social" set:html={icon} />
      ))}
    </div>
  </nav>
</div>

<style>
  /* ── Header & nav shell ── */
  header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.75rem clamp(1.5rem, 4vw, 5rem);
    background: transparent;
    pointer-events: none;
  }

  .logo,
  .hamburger,
  .desktop-links {
    pointer-events: auto;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: transparent;
    padding: 0;
    border: none;
    border-radius: 0;
    margin: 0;
    box-shadow: none;
    transition: none;
  }

  /* ── Logo ── */
  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: opacity 0.35s ease, transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    line-height: 1;
  }

  .logo:hover { opacity: 0.6; }

  .logo.logo-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .logo-img {
    height: 3.75rem;
    width: auto;
    display: block;
    padding: 0.4rem 0;
  }

  /* ── Desktop links ── */
  .desktop-links {
    list-style: none;
    display: none;
    margin: 0;
    padding: 0;
  }

  .desktop-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #F0ECE0;
    text-decoration: none;
    transition: color 0.2s;
    display: flex;
    align-items: center;
    line-height: 1;
  }

  .desktop-links a:hover,
  .desktop-links a.active { color: #C8A96E; }

  .social {
    display: flex;
    align-items: center;
    color: #F0ECE0;
    transition: color 0.2s;
  }

  .social:hover { color: #C8A96E; }

  .divider {
    width: 1px;
    height: 1.35rem;
    background: #F0ECE040;
  }

  /* ── Hamburger button ── */
  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 4px;
    color: #F0ECE0;
    transition: color 0.2s;
  }

  .hamburger:hover { color: #C8A96E; }

  .bar {
    display: block;
    height: 2.5px;
    border-radius: 2px;
    background: currentColor;
    transition: transform 0.32s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.25s ease,
                width 0.32s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bar-top { width: 26px; }
  .bar-mid { width: 18px; }   /* shorter — left-side trimmed */
  .bar-bot { width: 26px; }

  /* Morph to × when open */
  .hamburger.open .bar-top {
    width: 26px;
    transform: translateY(7.5px) rotate(45deg);
  }
  .hamburger.open .bar-mid {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger.open .bar-bot {
    width: 26px;
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* ── Overlay menu (mobile + desktop) ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: #0A0A08;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    padding: 0 clamp(2rem, 5vw, 6rem);
    opacity: 0;
    pointer-events: none;
    transform: none;
    transition: opacity 0.4s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: all;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0;
    width: auto;
    padding: 0;
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    width: auto;
  }

  .mobile-links > li {
    width: auto;
    border: none;
    padding: 0.35rem 0;
    transform: translateX(5rem);
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.4s ease;
  }


  .mobile-menu.open .mobile-links > li {
    transform: translateX(0);
    opacity: 1;
  }

  .mobile-menu.open .mobile-links > li:nth-child(1) { transition-delay: 0.06s; }
  .mobile-menu.open .mobile-links > li:nth-child(2) { transition-delay: 0.12s; }
  .mobile-menu.open .mobile-links > li:nth-child(3) { transition-delay: 0.18s; }


  .mobile-links a {
    font-family: "JetBrains Mono", monospace;
    font-size: 2.25rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.85);
    text-decoration: none;
    transition: color 0.2s;
    text-align: right;
  }

  .mobile-links a:hover,
  .mobile-links a.active { color: #C8A96E; }

  .mobile-socials {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.5rem;
    width: auto;
    margin-top: 1.5rem;
  }

  .mobile-social {
    color: #F0ECE0;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .mobile-social:hover { color: #C8A96E; }

  .mobile-social svg {
    width: 90px;
    height: 90px;
  }

  /* ── Work dropdown ── */
  .work-item {
    display: flex;
    flex-direction: column;
    width: auto;
    align-items: flex-end;
  }

  .work-toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.75rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 2.25rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.85);
    transition: color 0.2s;
  }

  .work-toggle:hover { color: #C8A96E; }

  .work-chevron {
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
    margin-top: 0.2em;
  }

  .work-toggle.open .work-chevron {
    transform: rotate(180deg);
  }

  .work-dropdown {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .work-dropdown.open {
    max-height: 600px;
  }

  .dropdown-category {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(200, 169, 110, 0.7);
    padding: 0.75rem 0 0.4rem;
    text-align: right;
    width: 100%;
  }

  .dropdown-film {
    display: flex;
    align-items: baseline;
    justify-content: flex-end;
    gap: 0.6rem;
    padding: 0.45rem 0;
    text-decoration: none;
    transition: color 0.2s;
    color: rgba(240, 236, 224, 0.72);
  }

  .dropdown-film:hover { color: #C8A96E; }

  .dropdown-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.25rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dropdown-year {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    color: rgba(240, 236, 224, 0.35);
  }

  .work-dropdown .dropdown-see-more {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
    padding: 0.55rem 0 0.2rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(240, 236, 224, 0.72);
    text-decoration: none;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .work-dropdown .dropdown-see-more:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  .work-dropdown .dropdown-see-more .see-more-arrow {
    transition: transform 0.2s ease;
  }

  .work-dropdown .dropdown-see-more:hover .see-more-arrow {
    transform: translate(2px, -2px);
  }

  .see-more-short { display: none; }

  @media (max-width: 768px) {
    .see-more-full  { display: none; }
    .see-more-short { display: inline; }
  }

  /* ── Desktop: larger logo scale ── */
  @media (min-width: 769px) {
    header.menu-open .logo {
      transform-origin: left center;
      transform: translateX(2.5rem) translateY(calc(50vh - 2.625rem)) scale(6);
    }
  }

  /* ── Mobile responsive breakpoint ── */
  @media (max-width: 768px) {
    nav {
      margin: 0;
      border-radius: 0;
      padding: 0.3rem 0;
    }

    .hamburger {
      position: relative;
      margin-right: 10px;
    }

    .hamburger::before {
      content: '';
      position: absolute;
      inset: -10px;
      border-radius: 50%;
      background: rgba(240, 236, 224, 0.12);
      backdrop-filter: blur(16px) saturate(1.8) brightness(1.05);
      -webkit-backdrop-filter: blur(16px) saturate(1.8) brightness(1.05);
      border: 1px solid rgba(240, 236, 224, 0.35);
      pointer-events: none;
      z-index: -1;
    }

    header.menu-open .logo {
      transform-origin: left center;
      transform: translateX(1.5rem) translateY(calc(50vh - 2.625rem)) scale(3);
    }
  }
</style>

<script>
  (() => {
    const header   = document.querySelector('#site-header') as HTMLElement;
    const btn      = document.querySelector('#hamburger-btn') as HTMLButtonElement | null;
    const menu     = document.querySelector('#mobile-menu') as HTMLElement | null;
    if (!header) return;

    const isHome = ['/', ''].includes(window.location.pathname);
    const logo   = document.querySelector('.logo') as HTMLElement | null;
    let menuOpen = false;
    let lastY    = window.scrollY;

    // ── Scrolled appearance ──
    function updateScrolled() {
      const past = !isHome || window.scrollY > window.innerHeight * 0.4;
      header.classList.toggle('scrolled', past);
    }

    window.addEventListener('scroll', () => {
      const currentY = window.scrollY;
      if (window.innerWidth <= 640 && !menuOpen) {
        if (currentY > lastY && currentY > 60) {
          logo?.classList.add('logo-hidden');
        } else {
          logo?.classList.remove('logo-hidden');
        }
      }
      lastY = currentY;
      updateScrolled();
    }, { passive: true });

    updateScrolled();

    // ── Hamburger toggle ──
    function openMenu() {
      menuOpen = true;
      btn?.classList.add('open');
      btn?.setAttribute('aria-expanded', 'true');
      menu?.classList.add('open');
      menu?.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      header.classList.remove('nav-hidden');
      header.classList.add('menu-open');
      logo?.classList.remove('logo-hidden');
    }

    function closeMenu() {
      menuOpen = false;
      btn?.classList.remove('open');
      btn?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('open');
      menu?.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      header.classList.remove('menu-open');
    }

    btn?.addEventListener('click', () => menuOpen ? closeMenu() : openMenu());

    // Close when any menu link is clicked
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMenu));

    // ── Work dropdown ──
    const workToggle = document.querySelector('#work-toggle') as HTMLButtonElement | null;
    const workDropdown = document.querySelector('#work-dropdown') as HTMLElement | null;

    workToggle?.addEventListener('click', () => {
      const isOpen = workToggle.getAttribute('aria-expanded') === 'true';
      workToggle.setAttribute('aria-expanded', String(!isOpen));
      workToggle.classList.toggle('open', !isOpen);
      workDropdown?.classList.toggle('open', !isOpen);
    });
  })();
</script>
