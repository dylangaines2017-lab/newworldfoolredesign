---
const projects = [
 {
    index: "I",
    title: "Accent",
    year: "2026",
    category: "Short Film",
    director: "Varun Giridhar",
    description: "An international student confronts his fellow TAs after overhearing a pejorative comment — with disastrous consequences.",
    image: "/films/placeholder/accent.jpeg",
    href: "/work?film=accent",
  },
  {
    index: "II",
    title: "Piggy",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "After bombing yet another open mic, a struggling obese comedian takes drastic measures to obtain the validation he has always craved.",
    image: "/FilmScreengrabs/Piggy_still.png",
    href: "/work?film=piggy",
  },
  {
    index: "III",
    title: "Mukbang’d",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "A mukbang influencer begins to film another day of her scarfing down and spitting out piles of food. Until a mysterious accident causes things to spiral out of control…",
    image: "/FilmScreengrabs/Mukbang_still.png",
    href: "/work?film=mukbangd",
  },
  {
    index: "IV",
    title: "Unforeseen",
    year: "2025",
    category: "Short Film",
    director: "Craig Helfer & Dylan Gaines",
    description: "An ambitious film crew shoots a horror film in what they think is an abandoned warehouse. But as the crew splinters, an unforeseen entity comes to visit.",
    image: "/FilmScreengrabs/Unforeseen_still.png",
    href: "/work?film=unforeseen",
  },
  {
    index: "V",
    title: "The Hunter",
    year: "2024",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "An arrogant hunter heads into the woods for what he thinks is a typical day of sport. But things change when it turns out he is the one being hunted…",
    image: "/FilmScreengrabs/Hunter_still.png",
    href: "/work?film=hunter",
  },
];
---

<section class="accordion">
  <div class="accordion-header">
    <h2 class="accordion-title">Selected <em>follies.</em></h2>
    <a href="/work" class="work-link">
      <span class="work-label">Browse Our Catalogue</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="work-arrow" aria-hidden="true">
        <path d="M7 7h10v10"/>
        <path d="M7 17 17 7"/>
      </svg>
    </a>
  </div>


  <div class="accordion-panels">
    {projects.map((p) => (
      <a href={p.href} class="project" aria-label={p.title}>
        <img src={p.image} alt={p.title} class="bg" />
        <div class="overlay" />

        <!-- Shown when collapsed -->
        <div class="collapsed-info">
          <span class="rotated-label"><span class="rotated-title">{p.title}</span>&ensp;<span class="rotated-year">{p.year}</span></span>
        </div>

        <!-- Shown when expanded -->
        <div class="expanded-info">
          <span class="index">{p.index}</span>
          <div class="details">
            <span class="meta">{p.year}&nbsp;·&nbsp;{p.category}</span>
            <h2 class="title">{p.title}</h2>
            <p class="description">{p.description}</p>
            <span class="director">dir. {p.director}</span>
          </div>
        </div>
      </a>
    ))}
  </div>

</section>

<style>
  .accordion {
    position: relative;
    display: flex;
    flex-direction: column;
    height: auto;
    min-height: calc(110svh - 3.85rem);
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .accordion-header {
    flex-shrink: 0;
    padding: 1.25rem 2rem 1rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .accordion-title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(3.55rem, 8.1vw, 8.1rem);
    font-weight: 400;
    color: #F0ECE0;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .accordion-title em {
    font-style: italic;
    background: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .work-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    gap: 0.4rem;
    text-decoration: none;
    color: rgba(240, 236, 224, 0.72);
    font-family: "JetBrains Mono", monospace;
    font-size: 1.125rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    width: fit-content;
    background-image: linear-gradient(currentColor, currentColor);
    background-size: 100% 1px;
    background-position: right bottom;
    background-repeat: no-repeat;
    transition: background-size 0.35s ease, color 0.2s;
  }

  .work-link:hover {
    color: #C8A96E;
    background-size: 0% 1px;
  }

  .work-label {
    display: inline-block;
  }

  .work-arrow {
    transition: transform 0.2s ease;
  }

  .work-link:hover .work-arrow {
    transform: translate(2px, -2px);
  }

  .accordion-panels {
    flex: 1;
    display: flex;
    gap: 2px;
    margin: 0 1.5rem 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    min-height: 480px;
    position: relative;
  }

  /* Inset gold border — only on wide viewports where content has room */
  .accordion-panels::after {
    content: '';
    position: absolute;
    inset: 14px;
    border-radius: 0.5rem;
    border: 2px solid rgba(200, 169, 110, 0.7);
    pointer-events: none;
    z-index: 10;
    box-sizing: border-box;
  }

  @media (max-width: 1280px), (max-height: 660px) {
    .accordion-panels::after {
      display: none;
    }

    .accordion-panels {
      border: 2px solid rgba(200, 169, 110, 0.7);
    }
  }

  @media (max-height: 660px) {
    .details {
      padding-bottom: 4.5rem;
    }
  }

  /* --- Panel sizing --- */
  .project {
    position: relative;
    flex: 0.4;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.75s cubic-bezier(0.22, 1, 0.36, 1);
    text-decoration: none;
    color: inherit;
    display: block;
    container-type: inline-size;
  }

  /* First panel expanded by default */
  .project:first-child {
    flex: 4;
  }

  /* Collapse first panel only when another panel is actively hovered */
  .accordion:has(.project:not(:first-child):hover) .project:first-child {
    flex: 0.4;
  }

  .accordion .project:not(:first-child):hover {
    flex: 4;
  }

  /* --- Background --- */
  .bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project:hover .bg {
    transform: scale(1.04);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.15) 100%);
  }

  /* --- Collapsed info (rotated title + year) --- */
  .collapsed-info {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem;
    overflow: hidden;
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .rotated-label {
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.08em;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: "Instrument Serif", serif;
  }

  .rotated-title {
    font-size: clamp(1rem, 5vw, 4.2rem);
  }

  .rotated-year {
    font-size: 1.05rem;
  }

  /* --- Expanded info --- */
  .expanded-info {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 2.5rem 3rem 3rem clamp(1.25rem, 3vw, 3.75rem);
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  .index {
    font-family: "Instrument Serif", serif;
    font-size: 4.2rem;
    font-style: italic;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .meta {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.975rem;
    color: #C8A96E;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s ease 0.3s, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
  }

  .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(6rem, 9vw, 10.5rem);
    font-weight: 400;
    color: #F0ECE0;
    white-space: nowrap;
    line-height: 1;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease 0s, transform 0.35s ease 0s;
  }

  .project:first-child .title,
  .accordion .project:not(:first-child):hover .title {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.25s;
  }

  .description {
    font-size: clamp(1.05rem, 1.4vw, 1.62rem);
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 55ch;
    margin-top: 1rem;
    opacity: 0;
    visibility: hidden;
    transition-property: opacity, visibility;
    transition-duration: 0.75s, 0s;
    transition-timing-function: ease, linear;
    transition-delay: 0s, 0s;
  }

  .project:first-child .description,
  .accordion .project:not(:first-child):hover .description {
    transition-delay: 0.35s, 0.35s;
  }

  .director {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    color: #C8A96E;
    text-transform: lowercase;
    margin-top: 0.4rem;
    opacity: 0;
    transition: opacity 0.25s ease 0.3s;
  }

  /* --- Expanded state --- */
  /* First child expanded by default */
  .project:first-child .collapsed-info { opacity: 0; transform: translateY(-10px); }
  .project:first-child .expanded-info  { opacity: 1; transform: translateY(0); }

  /* Revert first child only when another panel is hovered */
  .accordion:has(.project:not(:first-child):hover) .project:first-child .collapsed-info { opacity: 1; transform: translateY(0); }
  .accordion:has(.project:not(:first-child):hover) .project:first-child .expanded-info  { opacity: 0; transform: translateY(12px); }

  /* Hovered non-first panel gets expanded state */
  .accordion .project:not(:first-child):hover .collapsed-info { opacity: 0; transform: translateY(-10px); }
  .accordion .project:not(:first-child):hover .expanded-info  { opacity: 1; transform: translateY(0); }

  .accordion .project:not(:first-child):hover .meta,
  .accordion .project:not(:first-child):hover .description,
  .accordion .project:not(:first-child):hover .director,
  .project:first-child .meta,
  .project:first-child .description,
  .project:first-child .director {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  .accordion .project:not(:first-child):not(:hover) .expanded-info,
  .accordion .project:not(:first-child):not(:hover) .index,
  .accordion .project:not(:first-child):not(:hover) .meta,
  .accordion .project:not(:first-child):not(:hover) .description,
  .accordion .project:not(:first-child):not(:hover) .director {
    opacity: 0;
    visibility: hidden;
    transform: translateY(0);
    transition: opacity 0s ease 0s, visibility 0s linear 0s, transform 0s ease 0s;
  }

  .accordion:has(.project:not(:first-child):hover) .project:first-child .meta,
  .accordion:has(.project:not(:first-child):hover) .project:first-child .description,
  .accordion:has(.project:not(:first-child):hover) .project:first-child .director {
    opacity: 0;
    visibility: hidden;
    transform: translateY(0);
    transition: opacity 0s ease 0s, visibility 0s linear 0s;
  }

  .accordion:has(.project:not(:first-child):hover) .project:first-child .expanded-info {
    opacity: 0;
    transform: translateY(0);
    transition: opacity 0s ease 0s, transform 0s ease 0s;
  }

  .accordion:has(.project:not(:first-child):hover) .project:first-child .title {
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0s ease 0s, transform 0s ease 0s;
  }

  .project:first-child .meta,
  .project:first-child .description,
  .project:first-child .director {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
  }

  @media (max-width: 640px) {
    .accordion-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .work-link {
      padding: 0;
      gap: 0.47rem;
    }

    .work-label {
      font-size: 0.8rem;
    }

    .work-arrow {
      width: 13px;
      height: 13px;
    }

    /* Vertical accordion */
    .accordion {
      min-height: unset;
      height: auto;
    }

    .accordion-panels {
      flex-direction: column;
      flex: none;
      min-height: unset;
      margin: 0 2rem 0;
      border-radius: 0.75rem;
    }

    .collapsed-info {
      justify-content: flex-start;
      align-items: center;
      padding-left: 1.25rem;
    }

    .rotated-label {
      writing-mode: horizontal-tb;
      transform: none;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .rotated-title {
      font-size: 1.1rem;
    }

    .rotated-year {
      font-size: 0.75rem;
    }

    .title {
      font-size: clamp(3rem, 11vw, 5.5rem);
    }

    .description {
      font-size: 1.05rem;
    }

    .expanded-info {
      padding: 1rem;
    }
  }

  /* ── Mobile touch behavior ── */
  @media (hover: none) {
    /* Reset first-child default expanded state — JS will manage it */
    .project:first-child { flex: 0.4; }
    .project:first-child .collapsed-info { opacity: 1; transform: translateY(0); }
    .project:first-child .expanded-info  { opacity: 0; transform: translateY(12px); }
    .project:first-child .meta,
    .project:first-child .description { transform: translateY(6px); }

    /* Disable desktop hover overrides */
    .accordion:hover .project:first-child { flex: 0.4; }
    .accordion:hover .project:hover { flex: 0.4; }
    .accordion:hover .project:hover .collapsed-info { opacity: 1; }
    .accordion:hover .project:hover .expanded-info  { opacity: 0; }

    /* Touch-active: flex expansion + basic visibility (covers first-child case) */
    .project.touch-active { flex: 4; }
    .project.touch-active .bg { transform: scale(1.04); }
    .project.touch-active .collapsed-info { opacity: 0; transform: translateY(-10px); }
    .project.touch-active .expanded-info  { opacity: 1; transform: translateY(0); }

    /*
     * Non-first touch-active panels: use specificity (0,4,0) to beat
     * `.accordion .project:not(:first-child):not(:hover)` (also 0,4,0)
     * which keeps everything opacity:0 / visibility:hidden.
     * Being declared later in source order wins the tie.
     */
    .accordion .project.touch-active:not(:first-child) .expanded-info,
    .accordion .project.touch-active:not(:first-child) .index {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      transition: opacity 0.45s cubic-bezier(0.22, 1, 0.36, 1), transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .accordion .project.touch-active:not(:first-child) .title {
      opacity: 1;
      transform: translateY(0);
      transition: opacity 0.35s ease 0.25s, transform 0.35s ease 0.25s;
    }

    .accordion .project.touch-active:not(:first-child) .meta,
    .accordion .project.touch-active:not(:first-child) .director {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      transition: opacity 0.3s ease 0.2s, transform 0.45s cubic-bezier(0.22, 1, 0.36, 1) 0.1s;
    }

    .accordion .project.touch-active:not(:first-child) .description {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      transition: opacity 0.5s ease 0.3s, visibility 0s;
    }
  }

  /* ── Mobile: static film cards, no expand interaction ──
     Declared after hover:none so !important overrides win cleanly. */
  @media (max-width: 640px) {
    /* Every panel is a fixed-height card; JS never adds touch-active here */
    .project,
    .project:first-child {
      flex: none !important;
      height: 8rem;
    }

    /* Always hide the collapsed rotated-title strip */
    .collapsed-info,
    .project:first-child .collapsed-info {
      display: none !important;
    }

    /* Always show expanded content */
    .expanded-info,
    .project:first-child .expanded-info {
      opacity: 1 !important;
      transform: none !important;
      visibility: visible !important;
      justify-content: flex-end;   /* pin text to bottom of card */
      padding: 0.75rem 1rem;
    }

    /* Hide the large roman-numeral index — not enough room */
    .index { display: none !important; }

    .details { gap: 0.1rem; }

    .meta,
    .project:first-child .meta {
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
      transition: none !important;
      font-size: 0.68rem;
    }

    .title,
    .project:first-child .title {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
      font-size: 1.55rem;
      white-space: normal;
      line-height: 1.15;
    }

    /* Description is too long for compact cards — hide it */
    .description,
    .project:first-child .description {
      display: none !important;
    }

    .director,
    .project:first-child .director {
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
      transition: none !important;
      font-size: 0.68rem;
      margin-top: 0.1rem;
    }
  }
</style>

<script>
  // Scroll-driven width expansion on mobile
  if (window.matchMedia('(max-width: 640px)').matches) {
    const panels = document.querySelector<HTMLElement>('.accordion-panels')!;
    const accordion = document.querySelector<HTMLElement>('.accordion')!;
    if (panels && accordion) {
      const MAX_MARGIN = 32; // px (~2rem)
      const MAX_RADIUS = 12; // px (0.75rem)

      function updateExpansion() {
        const rect = accordion.getBoundingClientRect();
        const progress = Math.max(0, Math.min(1, (window.innerHeight - rect.top) / window.innerHeight));
        const m = MAX_MARGIN * (1 - progress);
        const r = MAX_RADIUS * (1 - progress);
        panels.style.margin = `0 ${m}px 0`;
        panels.style.borderRadius = `${r}px`;
      }

      window.addEventListener('scroll', updateExpansion, { passive: true });
      updateExpansion();
    }
  }

  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const isTouch  = navigator.maxTouchPoints > 0 || 'ontouchstart' in window;

  // On narrow mobile: panels are static cards — tapping navigates directly, no expand step.
  // On wider touch devices (tablets, touch laptops): keep tap-to-expand behavior.
  if (isTouch && !isMobile) {
    const accordion = document.querySelector('.accordion');
    if (accordion) {
      const panels = [...accordion.querySelectorAll<HTMLAnchorElement>('.project')];

      // Start with first panel active
      panels[0].classList.add('touch-active');

      panels.forEach((panel) => {
        let moved = false;

        panel.addEventListener('touchstart', () => { moved = false; }, { passive: true });
        panel.addEventListener('touchmove',  () => { moved = true;  }, { passive: true });

        panel.addEventListener('touchend', (e) => {
          if (moved) return;
          if (panel.classList.contains('touch-active')) {
            window.location.href = panel.href;
            return;
          }
          e.preventDefault();
          panels.forEach((p) => p.classList.remove('touch-active'));
          panel.classList.add('touch-active');
        }, { passive: false });

        // Click handler covers non-touch narrow-viewport browsers
        panel.addEventListener('click', (e) => {
          if (moved) return; // was a scroll gesture, not a tap
          if (!panel.classList.contains('touch-active')) {
            e.preventDefault();
            panels.forEach((p) => p.classList.remove('touch-active'));
            panel.classList.add('touch-active');
          }
        });
      });
    }
  }
</script>
