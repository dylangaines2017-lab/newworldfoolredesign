---
const projects = [
  {
    index: "I",
    title: "Piggy",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "After bombing yet another open mic, a struggling obese comedian takes drastic measures to obtain the validation he’s always craved.",
    image: "/FilmScreengrabs/Piggy_still.png",
    href: "/films/piggy",
  },
  {
    index: "II",
    title: "Mukbang’d",
    year: "2025",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "A mukbang influencer begins to film another day of her scarfing and spitting out piles of food. Until a mysterious accident causes things to spiral out of control…",
    image: "/FilmScreengrabs/Mukbang_still.png",
    href: "/films/mukbangd",
  },
  {
    index: "III",
    title: "Unforeseen",
    year: "2025",
    category: "Short Film",
    director: "Craig Helfer & Dylan Gaines",
    description: "An ambitious film crew shoots a horror film in what they think is an abandoned warehouse. But as the crew splinters, an unforeseen entity comes to visit.",
    image: "/FilmScreengrabs/Unforeseen_still.png",
    href: "/films/unforeseen",
  },
  {
    index: "IV",
    title: "The Hunter",
    year: "2024",
    category: "Short Film",
    director: "Dylan Gaines",
    description: "An arrogant hunter heads into the woods for what he thinks is a typical day of sport. But things change when it turns out he is the one being hunted…",
    image: "/FilmScreengrabs/Hunter_still.png",
    href: "/films/hunter",
  },
];
---

<section class="accordion">
  <div class="accordion-header">
    <h2 class="accordion-title">✦ Selected <em>follies.</em></h2>
    <a href="/work" class="work-link">
      <span class="work-label">Browse Our Catalogue</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="work-arrow" aria-hidden="true">
        <path d="M7 7h10v10"/>
        <path d="M7 17 17 7"/>
      </svg>
    </a>
  </div>


  <div class="accordion-panels">
    {projects.map((p) => (
      <a href={p.href} class="project" aria-label={p.title}>
        <img src={p.image} alt={p.title} class="bg" />
        <div class="overlay" />

        <!-- Shown when collapsed -->
        <div class="collapsed-info">
          <span class="rotated-label"><span class="rotated-title">{p.title}</span>&ensp;<span class="rotated-year">{p.year}</span></span>
        </div>

        <!-- Shown when expanded -->
        <div class="expanded-info">
          <span class="index">{p.index}</span>
          <div class="details">
            <span class="meta">{p.year}&nbsp;·&nbsp;{p.category}</span>
            <h2 class="title">{p.title}</h2>
            <p class="description">{p.description}</p>
            <span class="director">dir. {p.director}</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M8 3v10M3 9l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
</section>

<style>
  .accordion {
    position: relative;
    display: flex;
    flex-direction: column;
    height: calc(100svh - 3.5rem);
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .accordion-header {
    flex-shrink: 0;
    padding: 1.25rem 2rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .accordion-title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(3.55rem, 8.1vw, 8.1rem);
    font-weight: 400;
    color: #F0ECE0;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .accordion-title em {
    font-style: italic;
    background: linear-gradient(to right, #C8A96E, #F0D98A, #C8A96E);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .work-link {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    gap: 0.75rem;
    text-decoration: none;
    color: #C8A96E;
    border: 2px solid #C8A96E;
    border-radius: 0.5rem;
    padding: 0.85rem 2.5rem;
    background: linear-gradient(to right, #C8A96E 50%, #1C1C18 50%);
    background-size: 200% 100%;
    background-position: 100% 0;
    transition: background-position 0.5s ease, color 0.3s ease;
  }

  .work-link:hover {
    background-position: 0% 0;
    color: #0A0A08;
  }

  .work-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.275rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .work-arrow {
    transition: transform 0.2s ease;
  }

  .work-link:hover .work-arrow {
    transform: translate(2px, -2px);
  }

  .accordion-panels {
    flex: 1;
    display: flex;
    gap: 2px;
    margin: 0 1.5rem 1.5rem;
    border-radius: 0.75rem;
    overflow: hidden;
    min-height: 0;
    position: relative;
  }

  .accordion-panels::after {
    content: '';
    position: absolute;
    inset: 14px;
    border-radius: 0.5rem;
    border: 2px solid rgba(200, 169, 110, 0.7);
    pointer-events: none;
    z-index: 10;
    box-sizing: border-box;
  }

  /* --- Panel sizing --- */
  .project {
    position: relative;
    flex: 0.4;
    overflow: hidden;
    cursor: pointer;
    transition: flex 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  /* First panel expanded by default */
  .project:first-child {
    flex: 4;
  }

  /* Collapse first panel only when another panel is actively hovered */
  .accordion:has(.project:not(:first-child):hover) .project:first-child {
    flex: 0.4;
  }

  .accordion .project:not(:first-child):hover {
    flex: 4;
  }

  /* --- Background --- */
  .bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project:hover .bg {
    transform: scale(1.04);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.15) 100%);
  }

  /* --- Collapsed info (rotated title + year) --- */
  .collapsed-info {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  .rotated-label {
    color: rgba(255,255,255,0.7);
    letter-spacing: 0.08em;
    white-space: nowrap;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: "Instrument Serif", serif;
  }

  .rotated-title {
    font-size: 4.2rem;
  }

  .rotated-year {
    font-size: 1.05rem;
  }

  /* --- Expanded info --- */
  .expanded-info {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem 1.5rem 4rem 2.5rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .index {
    font-family: "Instrument Serif", serif;
    font-size: 4.2rem;
    font-style: italic;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em;
  }

  .details {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .meta {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.975rem;
    color: #C8A96E;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transform: translateY(6px);
    transition: transform 0.3s ease 0.1s;
  }

  .title {
    font-family: "Instrument Serif", serif;
    font-size: clamp(6rem, 9vw, 10.5rem);
    font-weight: 400;
    color: #F0ECE0;
    white-space: nowrap;
    line-height: 1;
  }

  .description {
    font-size: 1.62rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
    max-width: 55ch;
    margin-top: 1rem;
    transform: translateY(8px);
    transition: transform 0.3s ease 0.15s;
  }

  .director {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    color: #C8A96E;
    text-transform: lowercase;
    margin-top: 0.4rem;
  }

  /* --- Expanded state --- */
  /* First child expanded by default */
  .project:first-child .collapsed-info { opacity: 0; }
  .project:first-child .expanded-info  { opacity: 1; }

  /* Revert first child only when another panel is hovered */
  .accordion:has(.project:not(:first-child):hover) .project:first-child .collapsed-info { opacity: 1; }
  .accordion:has(.project:not(:first-child):hover) .project:first-child .expanded-info  { opacity: 0; }

  /* Hovered non-first panel gets expanded state */
  .accordion .project:not(:first-child):hover .collapsed-info { opacity: 0; }
  .accordion .project:not(:first-child):hover .expanded-info  { opacity: 1; }

  .accordion .project:not(:first-child):hover .meta,
  .accordion .project:not(:first-child):hover .description,
  .project:first-child .meta,
  .project:first-child .description {
    transform: translateY(0);
  }

  .accordion:has(.project:not(:first-child):hover) .project:first-child .meta,
  .accordion:has(.project:not(:first-child):hover) .project:first-child .description {
    transform: translateY(6px);
  }

  /* --- Scroll hint arrow --- */
  .scroll-hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(240, 236, 224, 0.55);
    animation: bounce 2s ease-in-out infinite;
    pointer-events: none;
    z-index: 2;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); opacity: 0.35; }
    50%       { transform: translateX(-50%) translateY(5px); opacity: 0.65; }
  }

  @media (max-width: 640px) {
    .accordion-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .work-link {
      padding: 0.53rem 1.56rem;
      gap: 0.47rem;
      border-width: 1px;
    }

    .work-label {
      font-size: 0.8rem;
    }

    .work-arrow {
      width: 13px;
      height: 13px;
    }

    /* Vertical accordion */
    .accordion-panels {
      flex-direction: column;
      margin: 0 2rem 1rem;
      border-radius: 0.75rem;
    }

    .accordion-panels::after {
      display: none;
    }

    .collapsed-info {
      justify-content: flex-start;
      align-items: center;
      padding-left: 1.25rem;
    }

    .rotated-label {
      writing-mode: horizontal-tb;
      transform: none;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }

    .rotated-title {
      font-size: 1.1rem;
    }

    .rotated-year {
      font-size: 0.75rem;
    }

    .title {
      font-size: clamp(3rem, 11vw, 5.5rem);
    }

    .description {
      font-size: 1.05rem;
    }

    .expanded-info {
      padding: 1rem;
    }
  }

  /* ── Mobile touch behavior ── */
  @media (hover: none) {
    /* Reset first-child default expanded state — JS will manage it */
    .project:first-child { flex: 0.4; }
    .project:first-child .collapsed-info { opacity: 1; }
    .project:first-child .expanded-info  { opacity: 0; }
    .project:first-child .meta,
    .project:first-child .description { transform: translateY(6px); }

    /* Disable desktop hover overrides */
    .accordion:hover .project:first-child { flex: 0.4; }
    .accordion:hover .project:hover { flex: 0.4; }
    .accordion:hover .project:hover .collapsed-info { opacity: 1; }
    .accordion:hover .project:hover .expanded-info  { opacity: 0; }

    /* Touch-active panel */
    .project.touch-active { flex: 4; }
    .project.touch-active .collapsed-info { opacity: 0; }
    .project.touch-active .expanded-info  { opacity: 1; }
    .project.touch-active .meta,
    .project.touch-active .description { transform: translateY(0); }
    .project.touch-active .bg { transform: scale(1.04); }
  }
</style>

<script>
  // Scroll-driven width expansion on mobile
  if (window.matchMedia('(max-width: 640px)').matches) {
    const panels = document.querySelector<HTMLElement>('.accordion-panels')!;
    const accordion = document.querySelector<HTMLElement>('.accordion')!;
    if (panels && accordion) {
      const MAX_MARGIN = 32; // px (~2rem)
      const MAX_RADIUS = 12; // px (0.75rem)

      function updateExpansion() {
        const rect = accordion.getBoundingClientRect();
        const progress = Math.max(0, Math.min(1, (window.innerHeight - rect.top) / window.innerHeight));
        const m = MAX_MARGIN * (1 - progress);
        const r = MAX_RADIUS * (1 - progress);
        panels.style.margin = `0 ${m}px 1rem`;
        panels.style.borderRadius = `${r}px`;
      }

      window.addEventListener('scroll', updateExpansion, { passive: true });
      updateExpansion();
    }
  }

  const isMobile = window.matchMedia('(max-width: 640px)').matches;
  const isTouch  = navigator.maxTouchPoints > 0 || 'ontouchstart' in window;

  if (isMobile || isTouch) {
    const accordion = document.querySelector('.accordion');
    if (accordion) {
      const panels = [...accordion.querySelectorAll<HTMLAnchorElement>('.project')];

      // Start with first panel active
      panels[0].classList.add('touch-active');

      panels.forEach((panel) => {
        let moved = false;

        panel.addEventListener('touchstart', () => { moved = false; }, { passive: true });
        panel.addEventListener('touchmove',  () => { moved = true;  }, { passive: true });

        panel.addEventListener('touchend', (e) => {
          if (moved) return;
          if (panel.classList.contains('touch-active')) {
            window.location.href = panel.href;
            return;
          }
          e.preventDefault();
          panels.forEach((p) => p.classList.remove('touch-active'));
          panel.classList.add('touch-active');
        }, { passive: false });

        // Click handler covers non-touch narrow-viewport browsers
        panel.addEventListener('click', (e) => {
          if (!panel.classList.contains('touch-active')) {
            e.preventDefault();
            panels.forEach((p) => p.classList.remove('touch-active'));
            panel.classList.add('touch-active');
          }
        });
      });
    }
  }
</script>
