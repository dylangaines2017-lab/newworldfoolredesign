---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  noSnap?: boolean;
}

const { title = "New World Fool Productions", noSnap = false } = Astro.props;
---

<html lang="en" class={noSnap ? "no-snap" : ""}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
    <div id="glass-cursor" aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="7" y1="17" x2="17" y2="7"/>
        <polyline points="11 7 17 7 17 13"/>
      </svg>
    </div>
  </body>
</html>

<script>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
  document.addEventListener('astro:after-swap', () => {
    window.scrollTo({ top: 0, left: 0, behavior: 'instant' });
  });

  // ── Glass cursor ──
  const glassCursor = document.getElementById('glass-cursor');
  if (glassCursor) {
    document.addEventListener('mousemove', (e) => {
      glassCursor.style.left = e.clientX + 'px';
      glassCursor.style.top  = e.clientY + 'px';
    }, { passive: true });

    document.addEventListener('mouseover', (e) => {
      const hit = (e.target as Element).closest('[data-cursor]');
      glassCursor.classList.toggle('active', !!hit);
    });
  }
</script>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: "Inter", system-ui, sans-serif;
    scroll-padding-top: 60px;
    overflow-x: hidden;
  }

  html.no-snap {
    scroll-snap-type: none;
  }

  @media (max-width: 768px) {
    html {
      scroll-snap-type: none;
    }
  }

  body {
    background: #000;
    color: #fff;
    min-height: 100vh;
    overflow-x: hidden;
  }

  main {
    padding: 0.75rem clamp(2.0625rem, 5.5vw, 6.875rem) 0;
  }

  @media (max-width: 900px) {
    main {
      padding: 0;
    }
  }

  #glass-cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(200, 169, 110, 0.15);
    backdrop-filter: blur(16px) saturate(1.8) brightness(1.05);
    -webkit-backdrop-filter: blur(16px) saturate(1.8) brightness(1.05);
    border: 1px solid rgba(200, 169, 110, 0.45);
    pointer-events: none;
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.18s ease;
    color: #C8A96E;
  }

  #glass-cursor.active {
    opacity: 1;
  }

  @media (hover: none) {
    #glass-cursor { display: none; }
  }
</style>
